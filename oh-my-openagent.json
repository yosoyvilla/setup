{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "disabled_agents": ["hephaestus"],

  "agents": {
    "sisyphus": {
      "model": "nan/deepseek-v4-flash",
      "reasoningEffort": "medium",
      "fallback_models": [
        { "model": "nan/mimo-v2.5" },
        { "model": "nan/qwen3.6", "temperature": 0.7 }
      ]
    },
    "prometheus": {
      "model": "nan/deepseek-v4-flash",
      "reasoningEffort": "high",
      "fallback_models": [
        { "model": "nan/mimo-v2.5" },
        { "model": "nan/qwen3.6", "temperature": 0.7 }
      ]
    },
    "metis": {
      "model": "nan/deepseek-v4-flash",
      "temperature": 0.5,
      "reasoningEffort": "medium",
      "fallback_models": [
        { "model": "nan/mimo-v2.5" },
        { "model": "nan/qwen3.6", "temperature": 0.7 }
      ]
    },
    "oracle": {
      "model": "nan/mimo-v2.5",
      "fallback_models": [
        { "model": "nan/deepseek-v4-flash" }
      ]
    },
    "momus": {
      "model": "nan/mimo-v2.5",
      "temperature": 0.1,
      "fallback_models": [
        { "model": "nan/deepseek-v4-flash" }
      ]
    },
    "multimodal-looker": {
      "model": "nan/mimo-v2.5",
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "atlas": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "explore": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "librarian": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "sisyphus-junior": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/deepseek-v4-flash" }
      ]
    }
  },

  "categories": {
    "quick": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "unspecified-low": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "unspecified-high": {
      "model": "nan/deepseek-v4-flash",
      "fallback_models": [
        { "model": "nan/mimo-v2.5" }
      ]
    },
    "writing": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    },
    "visual-engineering": {
      "model": "nan/mimo-v2.5",
      "fallback_models": [
        { "model": "nan/deepseek-v4-flash" }
      ]
    },
    "ultrabrain": {
      "model": "nan/mimo-v2.5",
      "fallback_models": [
        { "model": "nan/deepseek-v4-flash" }
      ]
    },
    "deep": {
      "model": "nan/deepseek-v4-flash",
      "reasoningEffort": "high",
      "fallback_models": [
        { "model": "nan/mimo-v2.5" }
      ]
    },
    "artistry": {
      "model": "nan/qwen3.6",
      "temperature": 0.7,
      "fallback_models": [
        { "model": "nan/gemma4", "temperature": 1.0 }
      ]
    }
  },

  "hashline_edit": true,

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 15,
    "timeout_seconds": 10,
    "notify_on_fallback": true
  },

  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 3 },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 5 }
      }
    }
  }
}
